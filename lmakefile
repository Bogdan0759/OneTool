string CC = "clang";
string CFLAGS = "-O3 -flto";
string LDFLAGS = "-static";
string LDLIBS = "-lssl -lcrypto -lz -lzstd -ldl -pthread -lncursesw -ltinfo";

string TARGET = "onetool";
string MAIN_SRC = "main.c";
string MAIN_OBJ = "main.o";
string MAIN_TUI_SRC = "tui.c";
string MAIN_TUI_OBJ = "tui.o";
string TOOL_REGISTRY_HDR = "config/tool_registry.h";
string EXTRA_TOOLS_MANIFEST = "config/extra_tools.manifest";
string EXTRA_TOOLS_SCRIPT = "tools/dev/build_extra_tools.sh";
string EXTRA_TOOLS_BUNDLE_OBJ = "generated/extra_tools_bundle.o";

string LASTMOD_SRC = "tools/filesystem/lastmod.c";
string LASTMOD_OBJ = "tools/filesystem/lastmod.o";
string EXEC_SRC = "tools/filesystem/exec.c";
string EXEC_OBJ = "tools/filesystem/exec.o";

string DOWN_HDR = "tools/network/down/down.h";
string DOWN_CLI_SRC = "tools/network/down/cli.c";
string DOWN_CLI_OBJ = "tools/network/down/cli.o";
string DOWN_PARSE_SRC = "tools/network/down/core/parse.c";
string DOWN_PARSE_OBJ = "tools/network/down/core/parse.o";
string DOWN_SEND_SRC = "tools/network/down/core/send.c";
string DOWN_SEND_OBJ = "tools/network/down/core/send.o";
string DOWN_ROBOTS_SRC = "tools/network/down/core/robots.c";
string DOWN_ROBOTS_OBJ = "tools/network/down/core/robots.o";

string NET_HDR = "libs/net/net.h";
string NET_URL_SRC = "libs/net/url.c";
string NET_URL_OBJ = "libs/net/url.o";
string NET_TRANSPORT_SRC = "libs/net/transport.c";
string NET_TRANSPORT_OBJ = "libs/net/transport.o";
string NET_HTTP_SRC = "libs/net/http.c";
string NET_HTTP_OBJ = "libs/net/http.o";
string NET_ROBOTS_SRC = "libs/net/robots.c";
string NET_ROBOTS_OBJ = "libs/net/robots.o";
string TUI_HDR = "libs/TUI/tui.h";
string TUI_SRC = "libs/TUI/tui.c";
string TUI_LIB_OBJ = "libs/TUI/tui.o";
string TUI_CFLAGS = "-D_DEFAULT_SOURCE -D_XOPEN_SOURCE=600";

string LMAKE_CLI_SRC = "tools/dev/lmake_cli.c";
string LMAKE_CLI_OBJ = "tools/dev/lmake_cli.o";
string LPACK_SRC = "tools/dev/packagers/lpack/lpack.c";
string LPACK_OBJ = "tools/dev/packagers/lpack/lpack.o";
string LPACK_RUNTIME_SRC = "tools/dev/packagers/lpack/runtime.c";
string LPACK_RUNTIME_BIN = "tools/dev/packagers/lpack/runtime.bin";

string REBOOT_SRC = "tools/power/reboot.c";
string REBOOT_OBJ = "tools/power/reboot.o";
string SHUTDOWN_SRC = "tools/power/shutdown.c";
string SHUTDOWN_OBJ = "tools/power/shutdown.o";
string TASKMNG_HDR = "tools/system/taskmng/taskmng.h";
string TASKMNG_INFO_SRC = "tools/system/taskmng/info.c";
string TASKMNG_INFO_OBJ = "tools/system/taskmng/info.o";
string TASKMNG_LIST_SRC = "tools/system/taskmng/list.c";
string TASKMNG_LIST_OBJ = "tools/system/taskmng/list.o";
string TASKMNG_PROCESS_SRC = "tools/system/taskmng/process.c";
string TASKMNG_PROCESS_OBJ = "tools/system/taskmng/process.o";
string TASKMNG_TUI_SRC = "tools/system/taskmng/tui.c";
string TASKMNG_TUI_OBJ = "tools/system/taskmng/tui.o";
string PING_CLI_SRC = "tools/network/ping/cli.c";
string PING_CLI_OBJ = "tools/network/ping/cli.o";
string LINK_OBJS = "main.o tui.o tools/filesystem/lastmod.o tools/filesystem/exec.o tools/network/down/cli.o tools/network/down/core/parse.o tools/network/down/core/send.o tools/network/down/core/robots.o libs/net/url.o libs/net/transport.o libs/net/http.o libs/net/robots.o libs/TUI/tui.o tools/network/ping/cli.o tools/dev/lmake_cli.o tools/dev/packagers/lpack/lpack.o tools/power/reboot.o tools/power/shutdown.o tools/system/taskmng/info.o tools/system/taskmng/list.o tools/system/taskmng/process.o tools/system/taskmng/tui.o";

task all() {
    build();
}

task build() {
    if (@is_outdated(MAIN_OBJ, MAIN_SRC, TOOL_REGISTRY_HDR, TASKMNG_HDR)) {
        @echo("[CC] %s", MAIN_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, MAIN_SRC, MAIN_OBJ);
    }
    if (@is_outdated(MAIN_TUI_OBJ, MAIN_TUI_SRC, TOOL_REGISTRY_HDR, TUI_HDR, TASKMNG_HDR)) {
        @echo("[CC] %s", MAIN_TUI_SRC);
        @run("%s %s %s -c %s -o %s", CC, CFLAGS, TUI_CFLAGS, MAIN_TUI_SRC, MAIN_TUI_OBJ);
    }

    if (@is_outdated(LASTMOD_OBJ, LASTMOD_SRC)) {
        @echo("[CC] %s", LASTMOD_SRC);
        @run("%s %s -Dmain=lm -c %s -o %s", CC, CFLAGS, LASTMOD_SRC, LASTMOD_OBJ);
    }
    if (@is_outdated(EXEC_OBJ, EXEC_SRC)) {
        @echo("[CC] %s", EXEC_SRC);
        @run("%s %s -Dmain=ex -c %s -o %s", CC, CFLAGS, EXEC_SRC, EXEC_OBJ);
    }
    if (@is_outdated(DOWN_CLI_OBJ, DOWN_CLI_SRC, DOWN_HDR)) {
        @echo("[CC] %s", DOWN_CLI_SRC);
        @run("%s %s -Dmain=dn -c %s -o %s", CC, CFLAGS, DOWN_CLI_SRC, DOWN_CLI_OBJ);
    }
    if (@is_outdated(PING_CLI_OBJ, PING_CLI_SRC)) {
        @echo("[CC] %s", PING_CLI_SRC);
        @run("%s %s -Dmain=pg -c %s -o %s", CC, CFLAGS, PING_CLI_SRC, PING_CLI_OBJ);
    }
    if (@is_outdated(LMAKE_CLI_OBJ, LMAKE_CLI_SRC)) {
        @echo("[CC] %s", LMAKE_CLI_SRC);
        @run("%s %s -Dmain=lk -c %s -o %s", CC, CFLAGS, LMAKE_CLI_SRC, LMAKE_CLI_OBJ);
    }
    if (@is_outdated(LPACK_OBJ, LPACK_SRC)) {
        @echo("[CC] %s", LPACK_SRC);
        @run("%s %s -Dmain=lp -c %s -o %s", CC, CFLAGS, LPACK_SRC, LPACK_OBJ);
    }
    if (@is_outdated(LPACK_RUNTIME_BIN, LPACK_RUNTIME_SRC)) {
        @echo("[CC] %s", LPACK_RUNTIME_SRC);
        @run("%s %s -fPIE -pie -s %s -o %s", CC, CFLAGS, LPACK_RUNTIME_SRC, LPACK_RUNTIME_BIN);
    }
    if (@is_outdated(REBOOT_OBJ, REBOOT_SRC)) {
        @echo("[CC] %s", REBOOT_SRC);
        @run("%s %s -Dmain=rb -c %s -o %s", CC, CFLAGS, REBOOT_SRC, REBOOT_OBJ);
    }
    if (@is_outdated(SHUTDOWN_OBJ, SHUTDOWN_SRC)) {
        @echo("[CC] %s", SHUTDOWN_SRC);
        @run("%s %s -Dmain=sd -c %s -o %s", CC, CFLAGS, SHUTDOWN_SRC, SHUTDOWN_OBJ);
    }
    if (@is_outdated(TASKMNG_TUI_OBJ, TASKMNG_TUI_SRC, TASKMNG_HDR, TUI_HDR)) {
        @echo("[CC] %s", TASKMNG_TUI_SRC);
        @run("%s %s %s -Dmain=tm -c %s -o %s", CC, CFLAGS, TUI_CFLAGS, TASKMNG_TUI_SRC, TASKMNG_TUI_OBJ);
    }
    if (@is_outdated(TASKMNG_INFO_OBJ, TASKMNG_INFO_SRC, TASKMNG_HDR)) {
        @echo("[CC] %s", TASKMNG_INFO_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, TASKMNG_INFO_SRC, TASKMNG_INFO_OBJ);
    }
    if (@is_outdated(TASKMNG_LIST_OBJ, TASKMNG_LIST_SRC, TASKMNG_HDR)) {
        @echo("[CC] %s", TASKMNG_LIST_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, TASKMNG_LIST_SRC, TASKMNG_LIST_OBJ);
    }
    if (@is_outdated(TASKMNG_PROCESS_OBJ, TASKMNG_PROCESS_SRC, TASKMNG_HDR, TUI_HDR)) {
        @echo("[CC] %s", TASKMNG_PROCESS_SRC);
        @run("%s %s %s -c %s -o %s", CC, CFLAGS, TUI_CFLAGS, TASKMNG_PROCESS_SRC, TASKMNG_PROCESS_OBJ);
    }

    if (@is_outdated(DOWN_PARSE_OBJ, DOWN_PARSE_SRC, DOWN_HDR, NET_HDR)) {
        @echo("[CC] %s", DOWN_PARSE_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, DOWN_PARSE_SRC, DOWN_PARSE_OBJ);
    }
    if (@is_outdated(DOWN_SEND_OBJ, DOWN_SEND_SRC, DOWN_HDR, NET_HDR)) {
        @echo("[CC] %s", DOWN_SEND_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, DOWN_SEND_SRC, DOWN_SEND_OBJ);
    }
    if (@is_outdated(DOWN_ROBOTS_OBJ, DOWN_ROBOTS_SRC, DOWN_HDR, NET_HDR)) {
        @echo("[CC] %s", DOWN_ROBOTS_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, DOWN_ROBOTS_SRC, DOWN_ROBOTS_OBJ);
    }
    if (@is_outdated(NET_URL_OBJ, NET_URL_SRC, NET_HDR)) {
        @echo("[CC] %s", NET_URL_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, NET_URL_SRC, NET_URL_OBJ);
    }
    if (@is_outdated(NET_TRANSPORT_OBJ, NET_TRANSPORT_SRC, NET_HDR)) {
        @echo("[CC] %s", NET_TRANSPORT_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, NET_TRANSPORT_SRC, NET_TRANSPORT_OBJ);
    }
    if (@is_outdated(NET_HTTP_OBJ, NET_HTTP_SRC, NET_HDR)) {
        @echo("[CC] %s", NET_HTTP_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, NET_HTTP_SRC, NET_HTTP_OBJ);
    }
    if (@is_outdated(NET_ROBOTS_OBJ, NET_ROBOTS_SRC, NET_HDR)) {
        @echo("[CC] %s", NET_ROBOTS_SRC);
        @run("%s %s -c %s -o %s", CC, CFLAGS, NET_ROBOTS_SRC, NET_ROBOTS_OBJ);
    }
    if (@is_outdated(TUI_LIB_OBJ, TUI_SRC, TUI_HDR)) {
        @echo("[CC] %s", TUI_SRC);
        @run("%s %s %s -c %s -o %s", CC, CFLAGS, TUI_CFLAGS, TUI_SRC, TUI_LIB_OBJ);
    }

    @echo("[GEN] extra tools");
    @run("CC='%s' CFLAGS='%s' sh %s %s %s", CC, CFLAGS, EXTRA_TOOLS_SCRIPT, EXTRA_TOOLS_MANIFEST, EXTRA_TOOLS_BUNDLE_OBJ);

    if (@is_outdated(TARGET,
        MAIN_OBJ,
        MAIN_TUI_OBJ,
        LASTMOD_OBJ,
        EXEC_OBJ,
        DOWN_CLI_OBJ,
        DOWN_PARSE_OBJ,
        DOWN_SEND_OBJ,
        DOWN_ROBOTS_OBJ,
        NET_URL_OBJ,
        NET_TRANSPORT_OBJ,
        NET_HTTP_OBJ,
        NET_ROBOTS_OBJ,
        TUI_LIB_OBJ,
        PING_CLI_OBJ,
        LMAKE_CLI_OBJ,
        LPACK_OBJ,
        LPACK_RUNTIME_BIN,
        REBOOT_OBJ,
        SHUTDOWN_OBJ,
        TASKMNG_TUI_OBJ,
        TASKMNG_INFO_OBJ,
        TASKMNG_LIST_OBJ,
        TASKMNG_PROCESS_OBJ,
        EXTRA_TOOLS_BUNDLE_OBJ
    )) {
        @echo("[LD] %s", TARGET);
        @run("%s %s %s -o %s %s %s", CC, LINK_OBJS, EXTRA_TOOLS_BUNDLE_OBJ, TARGET, LDFLAGS, LDLIBS);
        @echo("[CAP] setting cap_net_raw capability on %s", TARGET);
        @run("sudo setcap cap_net_raw+ep %s", TARGET);

    }

    @echo("[OK] build complete");
}

task clean() {
    @echo("[CLEAN] removing build artifacts");
    @run("rm -f %s", MAIN_OBJ);
    @run("rm -f %s", MAIN_TUI_OBJ);
    @run("rm -f %s", TARGET);
    @run("rm -f %s", LASTMOD_OBJ);
    @run("rm -f %s", EXEC_OBJ);
    @run("rm -f %s", DOWN_CLI_OBJ);
    @run("rm -f %s", DOWN_PARSE_OBJ);
    @run("rm -f %s", DOWN_SEND_OBJ);
    @run("rm -f %s", DOWN_ROBOTS_OBJ);
    @run("rm -f %s", "tools/network/down/net/socket.o");
    @run("rm -f %s", NET_URL_OBJ);
    @run("rm -f %s", NET_TRANSPORT_OBJ);
    @run("rm -f %s", NET_HTTP_OBJ);
    @run("rm -f %s", NET_ROBOTS_OBJ);
    @run("rm -f %s", TUI_LIB_OBJ);
    @run("rm -f %s", PING_CLI_OBJ);
    @run("rm -f %s", LMAKE_CLI_OBJ);
    @run("rm -f %s", LPACK_OBJ);
    @run("rm -f %s", LPACK_RUNTIME_BIN);
    @run("rm -f %s", REBOOT_OBJ);
    @run("rm -f %s", SHUTDOWN_OBJ);
    @run("rm -f %s", TASKMNG_TUI_OBJ);
    @run("rm -f %s", TASKMNG_INFO_OBJ);
    @run("rm -f %s", TASKMNG_LIST_OBJ);
    @run("rm -f %s", TASKMNG_PROCESS_OBJ);
    @run("rm -f %s", EXTRA_TOOLS_BUNDLE_OBJ);
    @run("rm -f %s", "generated/extra_tools_registry.c");
    @run("rm -f %s", "generated/extra_tools_registry.o");
    @run("rm -f %s", "generated/.tmp/extra_tools_bundle.o.tmp");
    @run("rm -f %s", "generated/.tmp/extra_tools_registry.c.tmp");
    @run("rm -rf %s", "generated/extra_tools");
    @run("rm -rf %s", "generated/.tmp");
    @run("rm -rf %s", "generated");
}

task run() {
    build();
    @run("./%s", TARGET);
}

task rebuild_lmake() {
    @run("zig build-exe -O ReleaseFast -fstrip -femit-bin=lmake tools/dev/lmake.zig");
}
